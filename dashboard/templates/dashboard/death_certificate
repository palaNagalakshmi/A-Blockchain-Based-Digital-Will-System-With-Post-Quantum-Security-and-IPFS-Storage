<form method="POST">
    {% csrf_token %}

    <h2>Generate Death Certificate</h2>

    <input type="text" name="aadhaar" placeholder="Aadhaar (12 digits)" required><br><br>

    <input type="text" name="father_name" placeholder="Father/Husband Name"><br><br>

    <input type="text" name="gender" placeholder="Gender"><br><br>

    <input type="text" name="address" placeholder="Address"><br><br>

    <input type="text" name="place_of_death" placeholder="Place of Death" required><br><br>

    <input type="date" name="date_of_death" required><br><br>

    <button type="submit">Generate Certificate</button>
</form>